# --- Simulation / Paper Trading ---
# Set to true to test without real funds using PolySimulator.com
SIMULATION_MODE=false
# Required if SIMULATION_MODE=true. Get at https://polysimulator.com
POLYSIMULATOR_API_KEY=
 
# --- Core Credentials ---
# Required if SIMULATION_MODE=false
PRIVATE_KEY=
# Your Polygon RPC URL (QuickNode, Alchemy, etc.)
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# EOA (Standard Wallet), PROXY (Magic/Gmail), or GNOSIS_SAFE
POLYMARKET_SIGNATURE_TYPE=EOA
 
# --- Target Wallets ---
# Comma-separated list of wallets to copy trade
TARGET_WALLETS=0xde17f7144fbd0eddb2679132c10ff5e74b120988,0x...
 
# --- Trading Logic ---
USE_SIZING_MODEL=true
SIZING_MULTIPLIER=1.5
MAX_TRADE_SIZE=100.0
# Safety cap: Never bet more than X% of your balance per trade (0.10 = 10%)
MAX_PERCENT_OF_BALANCE=0.10
# If true, will mirror the whale's literal dollar amount instead of proportional size
PREFER_LITERAL_WHALE_SIZE=true
 
# --- Execution Settings ---
# LIMIT, FOK, or FAK
ORDER_TYPE=FOK
SLIPPAGE_TOLERANCE=0.01
 
# --- Monitoring ---
POLL_INTERVAL=2000
WS_ASSET_IDS=
WS_MARKET_IDS=
 
# --- Registry ---
# Optional: Polymarket session token if you have one
POLYMARKET_GEO_TOKEN=
