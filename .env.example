# --- Simulation / Paper Trading ---
# Set to true to test without real funds using PolySimulator.com
SIMULATION_MODE=false
# Required if SIMULATION_MODE=true. Get at https://polysimulator.com
POLYSIMULATOR_API_KEY=

# --- Core Credentials ---
# Required if SIMULATION_MODE=false
PRIVATE_KEY=
# Your Polygon RPC URL (QuickNode, Alchemy, etc.)
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# EOA (Standard Wallet), PROXY (Magic/Gmail), or GNOSIS_SAFE
POLYMARKET_SIGNATURE_TYPE=EOA

# --- Target Discovery ---
# Comma-separated list of wallets to copy trade
TARGET_WALLETS=0xde17f7144fbd0eddb2679132c10ff5e74b120988
# Set to true to automatically follow the top 10 traders on polywhaler.io
USE_POLYWHALER_LEADERBOARD=false

# --- Dynamic Scalable Strategy ---
# Proportional sizing relative to whale (Auto-scales based on your balance)
USE_SIZING_MODEL=true
SIZING_MULTIPLIER=1.0
# Hard safety caps
MAX_TRADE_SIZE=10.0
MAX_DAILY_LOSS_PERCENT=20.0
# Whether to copy sell trades
COPY_SELLS=true

# --- Execution Settings ---
# Set to AUTO for the bot to handle ORDER_TYPE (LIMIT/FOK) and SLIPPAGE dynamically.
# Use LIMIT, FOK, or FAK for manual override.
ORDER_TYPE=AUTO
# Only used if ORDER_TYPE is not AUTO
SLIPPAGE_TOLERANCE=0.01

# --- Risk & Profit Management ---
# The bot uses a 3-tier adaptive TP/SL system:
# 1. Protection Tier (<$100): Tight 20% TP / 10% SL
# 2. Growth Tier ($100-$1k): Loose 50% TP / 25% SL
# 3. Whale Tier (>$1k): Pure mirror mode
TAKE_PROFIT_PERCENT=20
STOP_LOSS_PERCENT=10
AUTO_MARKET_THRESHOLD=100
ORDER_TIMEOUT_MINUTES=10

# --- Monitoring & Region ---
POLL_INTERVAL=2000
# Optional: Manual Geo-Token for bypassing restrictions
# POLYMARKET_GEO_TOKEN=
